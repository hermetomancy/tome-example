export const package = {
  name: "hello"
  version: "0.1.0"
  summary: "A tiny example Grimoire package"
  homepage: "https://example.com/hello"
  license: "MIT"
  targets: ["linux-x86_64-gnu" "linux-x86_64-musl" "linux-aarch64-gnu" "linux-aarch64-musl" "macos-x86_64-darwin" "macos-aarch64-darwin" "freebsd-x86_64-unknown" "freebsd-aarch64-unknown"]
  sources: {}
  deps: {
    build: {}
    runtime: []
  }
  bins: { hello: "bin/hello" }
}

export def build [ctx] {
  mkdir ($ctx.package_dir | path join "bin")
  "#!/usr/bin/env sh\nprintf 'hello from grimoire\n'\n" | save ($ctx.package_dir | path join "bin" "hello")
}
